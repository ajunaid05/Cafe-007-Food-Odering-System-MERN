# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/foodordering

# Auth (required in production)
JWT_SECRET=change_this_to_a_long_random_string

# CORS
FRONTEND_URL=http://localhost:3000

# Owner bootstrap (for seedOwner.js / migrateOwner.js only — do not commit real values)
OWNER_EMAIL=owner@restaurant.com
OWNER_PASSWORD=change_me_after_first_login

# Set to true only when you need to register a new owner via API
ALLOW_OWNER_SIGNUP=false

# Stripe (optional — payment routes return 503 if unset)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Currency: pkr (default) or usd for test with conversion
STRIPE_CURRENCY=pkr
# Only used when STRIPE_CURRENCY=usd (approx. 1 USD = 280 PKR → 0.0036)
STRIPE_PKR_TO_USD_RATE=0.0036

# Email (for forgot-password)
EMAIL_USER=
EMAIL_PASS=
